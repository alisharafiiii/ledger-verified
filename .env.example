# upstash redis (https://console.upstash.com → REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# eip-712 domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# bip-32 derivation path used by the in-browser signer (default: ethereum legacy)
NEXT_PUBLIC_LEDGER_DERIVATION_PATH=44'/60'/0'/0/0

# walletconnect v2 — required for ledger live mobile signing
# free signup: https://cloud.walletconnect.com → create project → copy id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
